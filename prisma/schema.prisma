generator client {
  provider = "prisma-client-js"
  output   = "../prisma/generated-schema"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum JenisKelamin {
  L
  P
}

enum StatusKehamilan {
  TIDAK_HAMIL
  HAMIL
  PASCA_PERSALINAN
}

enum UserRole {
  kader
  bidan
  admin
}

enum KategoriPendataan {
  balita
  imunisasi
  bumil
  pasca_persalinan
  lansia
}

enum StatusPendataan {
  draft
  selesai
}

model Posyandu {
  id         String   @id @default(uuid()) @db.Uuid

  nama       String
  rw         String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  users             User[]
  wargas            Warga[]
  pendataan_bulanan PendataanBulanan[]
  audit_logs        AuditLog[]

  @@map("posyandu")
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  auth_id     String   @unique @db.Uuid
  posyandu_id String?  @db.Uuid
  nama        String
  username    String   @unique
  role        UserRole @default(kader)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  posyandu          Posyandu?          @relation(fields: [posyandu_id], references: [id])
  pendataan_bulanan PendataanBulanan[]
  audit_logs        AuditLog[]

  @@index([posyandu_id])
  @@map("users")
}

model Warga {
  id               String          @id @default(uuid()) @db.Uuid
  posyandu_id      String          @db.Uuid
  nomor            String
  nik              String          @unique
  nama             String
  jenis_kelamin    JenisKelamin
  status_kehamilan StatusKehamilan @default(TIDAK_HAMIL)
  tanggal_lahir          DateTime        @db.Date
  tempat_lahir           String?
  alamat                 String?         @db.Text
  tempat_persalinan      String?
  penggunaan_kontrasepsi String?
  nama_ayah              String?
  nama_ibu               String?
  created_at             DateTime        @default(now())
  updated_at             DateTime        @updatedAt

  posyandu Posyandu @relation(fields: [posyandu_id], references: [id])

  pemeriksaan_balita_baduta    PemeriksaanBalitaBaduta[]
  riwayat_imunisasi            RiwayatImunisasi[]
  pemeriksaan_bumil            PemeriksaanBumil[]
  pemeriksaan_pasca_persalinan PemeriksaanPascaPersalinan[]
  pemeriksaan_lansia           PemeriksaanLansia[]

  @@index([posyandu_id])
  @@index([nik])
  @@map("warga")
}

model PemeriksaanBalitaBaduta {
  id                  String   @id @default(uuid()) @db.Uuid
  warga_id            String   @db.Uuid
  tanggal_kunjungan   DateTime @db.Date
  bb                  Decimal  @db.Decimal(5, 2)
  tb                  Decimal  @db.Decimal(5, 2)
  lingkar_kepala      Decimal  @db.Decimal(5, 2)
  lingkar_lengan_atas Decimal  @db.Decimal(5, 2)
  nama_ayah           String?
  nama_ibu            String?
  catatan                   String?   @db.Text
  kondisi                   String?
  asi_eksklusif             Boolean?
  fasilitasi_bantuan_sosial Boolean?
  tanggal_kunjungan_berikut DateTime? @db.Date
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt

  warga Warga @relation(fields: [warga_id], references: [id])

  @@index([warga_id])
  @@map("pemeriksaan_balita_baduta")
}

model RiwayatImunisasi {
  id                String   @id @default(uuid()) @db.Uuid
  warga_id          String   @db.Uuid
  jenis_vaksin      String
  tanggal_pemberian DateTime @db.Date
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  warga Warga @relation(fields: [warga_id], references: [id])

  @@index([warga_id])
  @@map("riwayat_imunisasi")
}

model PemeriksaanBumil {
  id                      String   @id @default(uuid()) @db.Uuid
  warga_id                String   @db.Uuid
  tanggal_kunjungan       DateTime @db.Date
  bb                      Decimal  @db.Decimal(5, 2)
  tb                      Decimal  @db.Decimal(5, 2)
  lingkar_perut           Decimal  @db.Decimal(5, 2)
  lingkar_lengan_atas     Decimal  @db.Decimal(5, 2)
  usia_kehamilan_minggu   Int
  hpht                    DateTime @db.Date
  htp                     DateTime @db.Date
  catatan                   String?   @db.Text
  jumlah_anak               Int?
  riwayat_penyakit          String?   @db.Text
  kadar_hemoglobin          Decimal?  @db.Decimal(5, 2)
  berat_janin               Decimal?  @db.Decimal(5, 2)
  terpapar_rokok            Boolean?
  kie                       Boolean?
  suplemen_tambah_darah     Boolean?
  tanggal_kunjungan_berikut DateTime? @db.Date
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt

  warga Warga @relation(fields: [warga_id], references: [id])

  @@index([warga_id])
  @@map("pemeriksaan_bumil")
}

model PemeriksaanPascaPersalinan {
  id                      String   @id @default(uuid()) @db.Uuid
  warga_id                String   @db.Uuid
  tanggal_kunjungan       DateTime @db.Date
  tanggal_persalinan      DateTime @db.Date
  bb                      Decimal  @db.Decimal(5, 2)
  tekanan_darah_sistolik  Int
  tekanan_darah_diastolik Int
  suhu_tubuh              Decimal  @db.Decimal(4, 2)
  kondisi_ibu             String?  @db.Text
  catatan                   String?   @db.Text
  tinggi_badan_bayi         Decimal?  @db.Decimal(5, 2)
  berat_badan_bayi          Decimal?  @db.Decimal(5, 2)
  kie                       Boolean?
  fasilitasi_rujukan        Boolean?
  fasilitasi_bantuan_sosial Boolean?
  tanggal_kunjungan_berikut DateTime? @db.Date
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt

  warga Warga @relation(fields: [warga_id], references: [id])

  @@index([warga_id])
  @@map("pemeriksaan_pasca_persalinan")
}

model PemeriksaanLansia {
  id                      String   @id @default(uuid()) @db.Uuid
  warga_id                String   @db.Uuid
  tanggal_kunjungan       DateTime @db.Date
  bb                      Decimal  @db.Decimal(5, 2)
  tb                      Decimal  @db.Decimal(5, 2)
  tekanan_darah_sistolik  Int
  tekanan_darah_diastolik Int
  gula_darah_sewaktu      Int
  catatan                 String?  @db.Text
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  warga Warga @relation(fields: [warga_id], references: [id])

  @@index([warga_id])
  @@map("pemeriksaan_lansia")
}

model PendataanBulanan {
  id           String            @id @default(uuid()) @db.Uuid
  posyandu_id  String            @db.Uuid
  bulan        Int
  tahun        Int
  status       StatusPendataan   @default(draft)
  submitted_at DateTime?
  submitted_by String?           @db.Uuid
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt

  posyandu Posyandu @relation(fields: [posyandu_id], references: [id])
  user     User?    @relation(fields: [submitted_by], references: [id])

  @@unique([posyandu_id, bulan, tahun])
  @@index([posyandu_id])
  @@map("pendataan_bulanan")
}
model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  posyandu_id String   @db.Uuid
  action      String   // "CREATE", "UPDATE", "DELETE", "SUBMIT"
  entity      String
  entity_id   String   @db.Uuid
  old_value   Json?
  new_value   Json?
  created_at  DateTime @default(now())

  user     User     @relation(fields: [user_id], references: [id])
  posyandu Posyandu @relation(fields: [posyandu_id], references: [id])

  @@index([posyandu_id])
  @@index([entity, entity_id])
  @@map("audit_log")
}
